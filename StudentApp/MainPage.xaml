<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="StudentApp.MainPage"
             BackgroundColor="{DynamicResource BackgroundLight}"
             Title="Student Project Home"
             Shell.NavBarIsVisible="False">

    <ContentPage.Resources>
        <Color x:Key="Primary">#197fe6</Color>
        <Color x:Key="BackgroundLight">#f6f7f8</Color>
        <Color x:Key="SurfaceLight">#ffffff</Color>
        <Color x:Key="Success">#22c55e</Color>
        <Color x:Key="Warning">#eab308</Color>
        <Color x:Key="PendingBg">#fefce8</Color>
        <Color x:Key="PendingText">#854d0e</Color>
    </ContentPage.Resources>

    <RefreshView x:Name="MainRefreshView" Refreshing="OnRefreshing" BackgroundColor="{StaticResource BackgroundLight}">
        <ScrollView BackgroundColor="{StaticResource BackgroundLight}">
            <VerticalStackLayout Padding="20,0,20,100" Spacing="16" BackgroundColor="{StaticResource BackgroundLight}">
                
                <!-- Header -->
                <Grid ColumnDefinitions="Auto, *" Margin="0,20,0,5">
                    <HorizontalStackLayout Grid.Column="0" Spacing="12">
                        <Border StrokeShape="RoundRectangle 25" Stroke="White" StrokeThickness="2" HeightRequest="48" WidthRequest="48">
                            <Image x:Name="ProfileImage" Source="https://res.cloudinary.com/djwpi6z29/image/upload/v1770699551/avatar-default-user-profile-icon-social-media-vector-57234208_y8gtgs.jpg" Aspect="AspectFill" />
                        </Border>
                        <VerticalStackLayout VerticalOptions="Center">
                            <Label x:Name="UserNameLabel" Text="" FontSize="18" FontAttributes="Bold" TextColor="{StaticResource Gray900}" />
                            <Label x:Name="UserRoleLabel" Text="Estudiante" FontSize="12" TextColor="{StaticResource Gray500}" />
                        </VerticalStackLayout>
                    </HorizontalStackLayout>
                </Grid>

                <!-- Section Title -->
                <Label Text="Mis Proyectos" FontSize="20" FontAttributes="Bold" TextColor="{StaticResource Gray800}" />

                <!-- Project List -->
                <StackLayout x:Name="ProjectListView" Spacing="16">
                    <!-- Populated dynamically from code-behind -->
                </StackLayout>
                
                <!-- Empty State -->
                <VerticalStackLayout x:Name="EmptyState" IsVisible="False" HorizontalOptions="Center" Spacing="12" Padding="0,40">
                    <Label Text="📭" FontSize="60" HorizontalOptions="Center"/>
                    <Label Text="No tienes proyectos asignados" FontSize="16" TextColor="{StaticResource Gray500}" HorizontalOptions="Center"/>
                    <Label Text="Desliza hacia abajo para actualizar" FontSize="12" TextColor="{StaticResource Gray400}" HorizontalOptions="Center"/>
                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>
    </RefreshView>
</ContentPage>
