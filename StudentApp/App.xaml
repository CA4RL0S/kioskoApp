<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:StudentApp"
             xmlns:converters="clr-namespace:StudentApp.Converters"
             x:Class="StudentApp.App">
    <Application.Resources>
        <ResourceDictionary>
            <converters:BoolToStatusBgConverter x:Key="BoolToStatusBgConverter" />
            <converters:BoolToStatusTextConverter x:Key="BoolToStatusTextConverter" />
            <converters:BoolToStatusTextColorConverter x:Key="BoolToStatusTextColorConverter" />
            <converters:BoolToStatusDotConverter x:Key="BoolToStatusDotConverter" />
            <converters:InvertBoolConverter x:Key="InvertBoolConverter" />
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
