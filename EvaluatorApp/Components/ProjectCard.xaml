<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="EvaluatorApp.Components.ProjectCard">

    <Border StrokeThickness="0" 
            BackgroundColor="{AppThemeBinding Light=White, Dark={StaticResource SurfaceDark}}" 
            StrokeShape="RoundRectangle 16">
        <Border.Shadow>
            <Shadow Brush="Black" Opacity="0.06" Radius="10" Offset="0,3"/>
        </Border.Shadow>

        <Grid RowDefinitions="200, Auto">

            <!-- Video / Image Area (16:9 aspect, top rounded corners) -->
            <Grid Grid.Row="0">
                <!-- Fallback Image (always rendered behind) -->
                <Image x:Name="ThumbnailImage"
                       Source="{Binding ImageUrl}" 
                       Aspect="AspectFill" 
                       BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray800}}"/>

                <!-- Video Player (only visible if project has video) -->
                <toolkit:MediaElement x:Name="VideoPlayer"
                                      IsVisible="False"
                                      ShouldAutoPlay="False"
                                      ShouldShowPlaybackControls="False"
                                      ShouldMute="True"
                                      ShouldLoopPlayback="True"
                                      Aspect="AspectFill"
                                      BackgroundColor="Black"/>

                <!-- Video duration badge (bottom right) -->
                <Border x:Name="VideoBadge"
                        IsVisible="False"
                        StrokeThickness="0"
                        BackgroundColor="#CC000000"
                        StrokeShape="RoundRectangle 6"
                        Padding="6,3"
                        HorizontalOptions="End"
                        VerticalOptions="End"
                        Margin="0,0,8,8">
                    <HorizontalStackLayout Spacing="4">
                        <Label Text="videocam" 
                               FontFamily="MaterialIcons" 
                               FontSize="12" 
                               TextColor="White" 
                               VerticalOptions="Center"/>
                        <Label Text="Video" 
                               FontSize="10" 
                               TextColor="White" 
                               FontAttributes="Bold"
                               VerticalOptions="Center"/>
                    </HorizontalStackLayout>
                </Border>
            </Grid>

            <!-- Info Area (below the video) -->
            <Grid Grid.Row="1" 
                  ColumnDefinitions="*, Auto" 
                  Padding="12,10,12,12" 
                  ColumnSpacing="8">

                <!-- Left: Title + Status -->
                <VerticalStackLayout Grid.Column="0" 
                                     VerticalOptions="Center" 
                                     Spacing="4">
                    <Label Text="{Binding Title}" 
                           TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark=White}" 
                           FontAttributes="Bold" 
                           FontSize="15" 
                           LineBreakMode="TailTruncation" 
                           MaxLines="2"/>

                    <HorizontalStackLayout Spacing="6">
                        <!-- Status Dot + Text -->
                        <BoxView Color="{Binding StatusColor}" 
                                 HeightRequest="8" 
                                 WidthRequest="8" 
                                 CornerRadius="4"
                                 VerticalOptions="Center"/>
                        <Label Text="{Binding StatusText}" 
                               TextColor="{Binding StatusTextColor}" 
                               FontSize="12" 
                               FontAttributes="Bold"
                               VerticalOptions="Center"/>
                    </HorizontalStackLayout>
                </VerticalStackLayout>

                <!-- Right: Score (only if evaluated) -->
                <Border Grid.Column="1" 
                        IsVisible="{Binding IsEvaluated}"
                        VerticalOptions="Center"
                        StrokeThickness="0"
                        BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray800}}"
                        StrokeShape="RoundRectangle 10"
                        Padding="10,6">
                    <HorizontalStackLayout Spacing="4">
                        <Label Text="⭐" FontSize="14" VerticalOptions="Center"/>
                        <Label Text="{Binding Score}" 
                               FontAttributes="Bold" 
                               FontSize="14" 
                               TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark=White}" 
                               VerticalOptions="Center"/>
                        <Label Text="/70" 
                               FontSize="11" 
                               TextColor="{StaticResource Gray400}" 
                               VerticalOptions="Center"/>
                    </HorizontalStackLayout>
                </Border>
            </Grid>
        </Grid>
    </Border>
</ContentView>
