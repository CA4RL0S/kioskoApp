<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="EvaluatorApp.LoginPage"
             Shell.NavBarIsVisible="False"
             Shell.FlyoutBehavior="Disabled"
             Shell.TabBarIsVisible="False"
             BackgroundColor="#0F172A">

    <ScrollView Orientation="Vertical" VerticalScrollBarVisibility="Never">
        <Grid VerticalOptions="Center" Padding="24" MinimumHeightRequest="700">

            <VerticalStackLayout Spacing="32" MaximumWidthRequest="420" HorizontalOptions="Center" VerticalOptions="Center">

                <!-- Logo Section -->
                <VerticalStackLayout Spacing="12" HorizontalOptions="Center" Margin="0,0,0,8">
                    <!-- Glowing Icon -->
                    <Border StrokeThickness="0"
                            BackgroundColor="#1E293B"
                            StrokeShape="RoundRectangle 24"
                            HeightRequest="80" WidthRequest="80"
                            HorizontalOptions="Center">
                        <Border.Shadow>
                            <Shadow Brush="{StaticResource Primary}" Opacity="0.3" Radius="30" Offset="0,0"/>
                        </Border.Shadow>
                        <Label Text="school"
                               FontFamily="MaterialIcons"
                               FontSize="40"
                               TextColor="{StaticResource Primary}"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"/>
                    </Border>

                    <Label Text="Kiosko Evaluadores"
                           FontSize="28"
                           FontAttributes="Bold"
                           TextColor="White"
                           HorizontalTextAlignment="Center"/>
                    <Label Text="Plataforma de evaluación académica"
                           FontSize="14"
                           TextColor="#94A3B8"
                           HorizontalTextAlignment="Center"/>
                </VerticalStackLayout>

                <!-- Form Card -->
                <Border StrokeThickness="1"
                        Stroke="#1E293B"
                        BackgroundColor="#1E293B"
                        StrokeShape="RoundRectangle 20"
                        Padding="24,28">
                    <Border.Shadow>
                        <Shadow Brush="Black" Opacity="0.3" Radius="20" Offset="0,8"/>
                    </Border.Shadow>

                    <VerticalStackLayout Spacing="20">

                        <!-- Email Field -->
                        <VerticalStackLayout Spacing="8">
                            <Label Text="Correo Institucional"
                                   FontSize="13"
                                   FontAttributes="Bold"
                                   TextColor="#CBD5E1"/>
                            <Border Stroke="#334155"
                                    StrokeShape="RoundRectangle 12"
                                    BackgroundColor="#0F172A"
                                    Padding="4,0">
                                <Grid ColumnDefinitions="44, *">
                                    <Label Text="mail"
                                           FontFamily="MaterialIcons"
                                           FontSize="20"
                                           TextColor="#64748B"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center"/>
                                    <Entry Grid.Column="1"
                                           x:Name="EmailEntry"
                                           Placeholder="usuario@institucion.edu"
                                           Keyboard="Email"
                                           HeightRequest="50"
                                           TextColor="White"
                                           PlaceholderColor="#475569"
                                           BackgroundColor="Transparent"/>
                                </Grid>
                            </Border>
                        </VerticalStackLayout>

                        <!-- Password Field -->
                        <VerticalStackLayout Spacing="8">
                            <Label Text="Contraseña"
                                   FontSize="13"
                                   FontAttributes="Bold"
                                   TextColor="#CBD5E1"/>
                            <Border Stroke="#334155"
                                    StrokeShape="RoundRectangle 12"
                                    BackgroundColor="#0F172A"
                                    Padding="4,0">
                                <Grid ColumnDefinitions="44, *">
                                    <Label Text="lock"
                                           FontFamily="MaterialIcons"
                                           FontSize="20"
                                           TextColor="#64748B"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center"/>
                                    <Entry Grid.Column="1"
                                           x:Name="PasswordEntry"
                                           Placeholder="••••••••"
                                           IsPassword="True"
                                           HeightRequest="50"
                                           TextColor="White"
                                           PlaceholderColor="#475569"
                                           BackgroundColor="Transparent"/>
                                </Grid>
                            </Border>
                        </VerticalStackLayout>

                        <!-- Login Button with Loading Spinner -->
                        <Grid HeightRequest="56" Margin="0,4,0,0">
                            <Button x:Name="LoginBtn"
                                    Text="Iniciar Sesión"
                                    Clicked="OnLoginClicked"
                                    BackgroundColor="{StaticResource Primary}"
                                    TextColor="White"
                                    FontAttributes="Bold"
                                    FontSize="16"
                                    CornerRadius="12"
                                    HeightRequest="56"/>

                            <!-- Loading overlay (hidden by default) -->
                            <Border x:Name="LoadingOverlay"
                                    IsVisible="False"
                                    StrokeThickness="0"
                                    BackgroundColor="{StaticResource Primary}"
                                    StrokeShape="RoundRectangle 12"
                                    HeightRequest="56"
                                    InputTransparent="False">
                                <HorizontalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="12">
                                    <ActivityIndicator IsRunning="True" Color="White" HeightRequest="24" WidthRequest="24"/>
                                    <Label Text="Conectando..." TextColor="White" FontSize="16" FontAttributes="Bold" VerticalOptions="Center"/>
                                </HorizontalStackLayout>
                            </Border>
                        </Grid>

                    </VerticalStackLayout>
                </Border>

                <!-- Footer -->
                <VerticalStackLayout Spacing="16" HorizontalOptions="Center">
                    <!-- Sign Up -->
                    <Label HorizontalOptions="Center" FontSize="14" TextColor="#64748B">
                        <Label.FormattedText>
                            <FormattedString>
                                <Span Text="¿No tienes cuenta? " />
                                <Span Text="Regístrate aquí"
                                      TextColor="{StaticResource Primary}"
                                      FontAttributes="Bold">
                                    <Span.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnSignUpClicked"/>
                                    </Span.GestureRecognizers>
                                </Span>
                            </FormattedString>
                        </Label.FormattedText>
                    </Label>

                    <HorizontalStackLayout Spacing="8" HorizontalOptions="Center" Opacity="0.4">
                        <BoxView Color="#475569" HeightRequest="4" WidthRequest="4" CornerRadius="2" VerticalOptions="Center"/>
                        <Label Text="Versión 2.4.0" FontSize="11" TextColor="#475569"/>
                        <BoxView Color="#475569" HeightRequest="4" WidthRequest="4" CornerRadius="2" VerticalOptions="Center"/>
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </VerticalStackLayout>
        </Grid>
    </ScrollView>
</ContentPage>
