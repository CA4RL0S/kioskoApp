<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="EvaluatorApp.LoginPage"
             Shell.NavBarIsVisible="False"
             Shell.FlyoutBehavior="Disabled"
             Shell.TabBarIsVisible="False"
             BackgroundColor="#0F172A">

    <ScrollView Orientation="Vertical" VerticalScrollBarVisibility="Never">
        <Grid VerticalOptions="Center" Padding="40,0" MinimumHeightRequest="700">

            <VerticalStackLayout Spacing="36" HorizontalOptions="Fill" VerticalOptions="Center">

                <!-- Logo + Title -->
                <VerticalStackLayout Spacing="8" HorizontalOptions="Center" Margin="0,0,0,12">
                    <!-- App Logo -->
                    <Image Source="appicon"
                           HeightRequest="72"
                           WidthRequest="72"
                           HorizontalOptions="Center"
                           Margin="0,0,0,4"/>
                    <Label Text="Kiosko"
                           FontSize="36"
                           FontAttributes="Bold"
                           TextColor="White"
                           HorizontalTextAlignment="Center"/>
                    <Label Text="Plataforma de evaluación académica"
                           FontSize="15"
                           TextColor="#94A3B8"
                           HorizontalTextAlignment="Center"/>
                </VerticalStackLayout>

                <!-- Form -->
                <VerticalStackLayout Spacing="20" HorizontalOptions="Fill">

                    <!-- Email -->
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Correo Institucional"
                               FontSize="14"
                               FontAttributes="Bold"
                               TextColor="#CBD5E1"/>
                        <Border Stroke="#334155"
                                StrokeShape="RoundRectangle 12"
                                BackgroundColor="#1E293B"
                                StrokeThickness="1"
                                Padding="16,4"
                                HeightRequest="52">
                            <Entry x:Name="EmailEntry"
                                   Placeholder="usuario@institucion.edu"
                                   Keyboard="Email"
                                   TextColor="White"
                                   PlaceholderColor="#475569"
                                   BackgroundColor="Transparent"
                                   FontSize="16"
                                   VerticalOptions="Center"
                                   HorizontalOptions="Fill"/>
                        </Border>
                    </VerticalStackLayout>

                    <!-- Password -->
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Contraseña"
                               FontSize="14"
                               FontAttributes="Bold"
                               TextColor="#CBD5E1"/>
                        <Border Stroke="#334155"
                                StrokeShape="RoundRectangle 12"
                                BackgroundColor="#1E293B"
                                StrokeThickness="1"
                                Padding="16,4"
                                HeightRequest="52">
                            <Grid ColumnDefinitions="*, Auto" HorizontalOptions="Fill">
                                <Entry x:Name="PasswordEntry"
                                       Placeholder="Ingresa tu contraseña"
                                       IsPassword="True"
                                       TextColor="White"
                                       PlaceholderColor="#475569"
                                       BackgroundColor="Transparent"
                                       FontSize="16"
                                       VerticalOptions="Center"
                                       HorizontalOptions="Fill"/>
                                <ImageButton Grid.Column="1"
                                             x:Name="TogglePasswordBtn"
                                             Clicked="OnTogglePassword"
                                             BackgroundColor="Transparent"
                                             HeightRequest="24"
                                             WidthRequest="24"
                                             VerticalOptions="Center"
                                             Margin="0,0,8,0"
                                             Opacity="0.7">
                                    <ImageButton.Source>
                                        <FontImageSource FontFamily="MaterialIcons"
                                                         Glyph="visibility_off"
                                                         Color="#94A3B8"
                                                         Size="20"/>
                                    </ImageButton.Source>
                                </ImageButton>
                            </Grid>
                        </Border>
                    </VerticalStackLayout>

                    <!-- Login Button -->
                    <Grid HeightRequest="52" Margin="0,8,0,0">
                        <Button x:Name="LoginBtn"
                                Text="Iniciar Sesión"
                                Clicked="OnLoginClicked"
                                BackgroundColor="{StaticResource Primary}"
                                TextColor="White"
                                FontAttributes="Bold"
                                FontSize="17"
                                CornerRadius="12"
                                HeightRequest="52"/>

                        <Border x:Name="LoadingOverlay"
                                IsVisible="False"
                                StrokeThickness="0"
                                BackgroundColor="{StaticResource Primary}"
                                StrokeShape="RoundRectangle 12"
                                HeightRequest="52"
                                InputTransparent="False">
                            <HorizontalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="12">
                                <ActivityIndicator IsRunning="True" Color="White" HeightRequest="22" WidthRequest="22"/>
                                <Label Text="Conectando..." TextColor="White" FontSize="17" FontAttributes="Bold" VerticalOptions="Center"/>
                            </HorizontalStackLayout>
                        </Border>
                    </Grid>
                </VerticalStackLayout>

                <!-- Footer -->
                <VerticalStackLayout Spacing="16" HorizontalOptions="Center">
                    <Label HorizontalOptions="Center" FontSize="15" TextColor="#64748B">
                        <Label.FormattedText>
                            <FormattedString>
                                <Span Text="¿No tienes cuenta? " />
                                <Span Text="Regístrate"
                                      TextColor="{StaticResource Primary}"
                                      FontAttributes="Bold">
                                    <Span.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnSignUpClicked"/>
                                    </Span.GestureRecognizers>
                                </Span>
                            </FormattedString>
                        </Label.FormattedText>
                    </Label>

                    <Label Text="v2.4.0" FontSize="12" TextColor="#334155" HorizontalOptions="Center" Opacity="0.6"/>
                </VerticalStackLayout>
            </VerticalStackLayout>
        </Grid>
    </ScrollView>
</ContentPage>
